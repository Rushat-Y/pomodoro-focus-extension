{
  "manifest_version": 2,
  "name": "Pomodoro Focus",
  "version": "1.1.0",
  "description": "A sleek, modern Pomodoro timer with stats dashboard, task labels, and website blocker.",
  "author": "Pomodoro Focus",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Pomodoro Focus"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "alarms",
    "webRequest",
    "webRequestBlocking",
    "*://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pomodoro-focus@rushat-y.github.io",
      "strict_min_version": "91.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}